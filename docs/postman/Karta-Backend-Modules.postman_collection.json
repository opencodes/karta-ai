{
  "info": {
    "name": "Karta Backend Modules",
    "description": "Auth + modular backend APIs (EduKarta, PrepKarta)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "email",
      "value": "member@karta.ai.in"
    },
    {
      "key": "password",
      "value": "member123"
    },
    {
      "key": "rawInput",
      "value": "Pay electricity bill tomorrow at 4 PM"
    },
    {
      "key": "taskId",
      "value": ""
    },
    {
      "key": "planName",
      "value": "edu-prep-bundle"
    },
    {
      "key": "upgradePlanName",
      "value": "edu-prep-bundle"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/signup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "signup"
              ]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('login returned token', function () { pm.expect(json.token).to.be.a('string').and.not.empty; });",
                  "if (json.token) {",
                  "  const token = String(json.token).trim();",
                  "  pm.collectionVariables.set('token', token);",
                  "  pm.environment.set('token', token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "me"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Billing",
      "item": [
        {
          "name": "Catalog Modules",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/billing/catalog/modules",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "billing",
                "catalog",
                "modules"
              ]
            }
          }
        },
        {
          "name": "Catalog Packages",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/billing/catalog/packages",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "billing",
                "catalog",
                "packages"
              ]
            }
          }
        },
        {
          "name": "My Access",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/billing/my-access",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "billing",
                "my-access"
              ]
            }
          }
        },
        {
          "name": "Buy Module (EduKarta - paid)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"moduleName\": \"edukarta\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/billing/buy-module",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "billing",
                "buy-module"
              ]
            }
          }
        },
        {
          "name": "Buy Package (Edu+Prep)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"planName\": \"{{planName}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/billing/buy-package",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "billing",
                "buy-package"
              ]
            }
          }
        },
        {
          "name": "My Subscriptions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/billing/my-subscriptions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "billing",
                "my-subscriptions"
              ]
            }
          }
        },
        {
          "name": "Upgrade Options",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/billing/upgrade-options",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "billing",
                "upgrade-options"
              ]
            }
          }
        },
        {
          "name": "Upgrade Plan",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"toPlanName\": \"{{upgradePlanName}}\",\n  \"deactivateCurrent\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/billing/upgrade",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "billing",
                "upgrade"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "TodoKarta",
      "item": [
        {
          "name": "Overview",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/edukarta/overview",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "edukarta",
                "overview"
              ]
            }
          }
        },
        {
          "name": "List Tasks",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/todokarta/tasks?bucket=all",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "edukarta",
                "tasks"
              ],
              "query": [
                {
                  "key": "bucket",
                  "value": "all"
                }
              ]
            }
          }
        },
        {
          "name": "Create Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.task?.id) pm.collectionVariables.set('taskId', json.task.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rawInput\": \"{{rawInput}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/todokarta/tasks/parse-create",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "edukarta",
                "tasks",
                "parse-create"
              ]
            }
          }
        },
        {
          "name": "Feature Task",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"featured\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/todokarta/tasks/{{taskId}}/feature",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "edukarta",
                "tasks",
                "{{taskId}}",
                "feature"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "PrepKarta",
      "item": [
        {
          "name": "Exams",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/prepkarta/exams",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "prepkarta",
                "exams"
              ]
            }
          }
        }
      ]
    }
  ]
}
